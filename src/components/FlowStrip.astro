---
/*
 * FlowStrip — the signature element.
 * A live, horizontally-scrolling strip of window columns: a miniature of
 * Nehir itself.
 *
 * Selection is per *window*, mirroring Nehir's real focus model: the focus
 * ring targets an individual window — a stacked window inside a column, or the
 * active tab inside a tabbed column — never a whole column. Arrow keys navigate
 * like ⌥⌘Arrow "go there": Left/Right move across columns (landing on each
 * column's active window), Up/Down move within the focused column — between
 * stacked windows, or cycling tabs in a tabbed column.
 *
 * Tabbed columns render as a thin vertical rail of peels along the column's
 * left edge (no labels), exactly like Nehir's TabbedColumnOverlay. Clicking a
 * peel switches the visible tab. The workspace switcher swaps the whole strip
 * to a different mock arrangement.
 */
type Win = { app: string; kind: string; lines: number };
type Col = { width: "narrow" | "normal" | "wide"; mode?: "tabs"; windows: Win[] };
type Workspace = { key: string; label: string; focus: number; columns: Col[] };

const workspaces: Workspace[] = [
  {
    key: "code",
    label: "code",
    focus: 1,
    columns: [
      { width: "normal", windows: [{ app: "Terminal", kind: "term", lines: 7 }] },
      { width: "wide", windows: [{ app: "Editor", kind: "edit", lines: 9 }] },
      {
        width: "normal",
        windows: [
          { app: "Safari", kind: "web", lines: 3 },
          { app: "Docs", kind: "doc", lines: 4 },
        ],
      },
      {
        width: "narrow",
        mode: "tabs",
        windows: [
          { app: "Slack", kind: "chat", lines: 5 },
          { app: "Mail", kind: "doc", lines: 5 },
          { app: "Linear", kind: "doc", lines: 5 },
        ],
      },
      { width: "normal", windows: [{ app: "Music", kind: "media", lines: 4 }] },
      { width: "wide", windows: [{ app: "Xcode", kind: "edit", lines: 9 }] },
    ],
  },
  {
    key: "comms",
    label: "comms",
    focus: 0,
    columns: [
      {
        width: "narrow",
        mode: "tabs",
        windows: [
          { app: "Slack", kind: "chat", lines: 6 },
          { app: "Mail", kind: "doc", lines: 5 },
          { app: "Messages", kind: "chat", lines: 4 },
        ],
      },
      { width: "wide", windows: [{ app: "Mail", kind: "doc", lines: 8 }] },
      {
        width: "normal",
        windows: [
          { app: "Calendar", kind: "doc", lines: 3 },
          { app: "Reminders", kind: "doc", lines: 4 },
        ],
      },
      { width: "normal", windows: [{ app: "Zoom", kind: "media", lines: 5 }] },
    ],
  },
  {
    key: "read",
    label: "read",
    focus: 0,
    columns: [
      { width: "wide", windows: [{ app: "Safari", kind: "web", lines: 9 }] },
      {
        width: "normal",
        windows: [
          { app: "Docs", kind: "doc", lines: 4 },
          { app: "Notes", kind: "doc", lines: 5 },
        ],
      },
      {
        width: "normal",
        mode: "tabs",
        windows: [
          { app: "Wikipedia", kind: "web", lines: 6 },
          { app: "arXiv", kind: "doc", lines: 6 },
          { app: "Reader", kind: "doc", lines: 6 },
        ],
      },
      { width: "narrow", windows: [{ app: "Music", kind: "media", lines: 4 }] },
    ],
  },
];

const initial = workspaces[0];
const initialWin = `fs-${initial.key}-${initial.focus}-0`;
---

<figure class="strip" aria-label="Interactive preview of windows arranged in scrolling columns">
  <div class="strip-chrome">
    <span class="strip-dot" style="--d:#ff5f57"></span>
    <span class="strip-dot" style="--d:#febc2e"></span>
    <span class="strip-dot" style="--d:#28c840"></span>
    <span class="strip-ws" role="group" aria-label="Workspaces">
      {workspaces.map((ws, i) => (
        <button
          type="button"
          class={`ws-name${i === 0 ? " is-active" : ""}`}
          id={`fs-ws-${ws.key}`}
          data-ws-btn={ws.key}
          aria-pressed={i === 0 ? "true" : "false"}
        >{ws.label}</button>
      ))}
    </span>
    <span class="strip-hint mono">arrows to flow</span>
  </div>

  <div class="strip-viewport" id="flow-viewport" tabindex="0" role="listbox"
       aria-activedescendant={initialWin}
       aria-label="Windows in scrolling columns. Left and right arrows move between columns, up and down move within the focused column or cycle tabs.">
    {workspaces.map((ws, wsi) => (
      <div class="strip-track" data-ws={ws.key} data-focus={ws.focus} hidden={wsi !== 0}>
        {ws.columns.map((col, c) => (
          <div class={`col col-${col.width}${col.mode === "tabs" ? " col-tabs" : ""}`}
               data-col={c} data-mode={col.mode ?? "stack"} data-active="0">
            {col.mode === "tabs" && (
              <div class="col-peels" aria-hidden="true">
                {col.windows.map((w, t) => (
                  <span class={`peel${t === 0 ? " is-active" : ""}`} data-peel={t} title={w.app}></span>
                ))}
              </div>
            )}
            <div class="col-windows">
              {col.windows.map((w, t) => (
                <div class={`win win-${w.kind}`} role="option" id={`fs-${ws.key}-${c}-${t}`}
                     data-app={w.app}
                     aria-selected={wsi === 0 && c === ws.focus && t === 0 ? "true" : "false"}
                     hidden={col.mode === "tabs" && t !== 0}>
                  <div class="win-bar">
                    <span class="win-app">{w.app}</span>
                  </div>
                  <div class={`win-body body-${w.kind}`}>
                    {Array.from({ length: w.lines }).map((_, li) => (
                      <span class="ln" style={`--lw:${45 + ((li * 37) % 50)}%`}></span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    ))}
    <div class="focus-ring" id="flow-ring" aria-hidden="true"></div>
  </div>

  <p class="strip-live sr-only" id="flow-live" aria-live="polite"></p>

  <figcaption class="strip-controls">
    <button class="strip-arrow" id="flow-prev" aria-label="Focus previous column">←</button>
    <span class="strip-cap mono">Focus a window — columns scroll, tabs peel, nothing gets squeezed.</span>
    <button class="strip-arrow" id="flow-next" aria-label="Focus next column">→</button>
  </figcaption>
</figure>

<style>
  .strip {
    margin: 0;
    background: linear-gradient(180deg, #0d0f15, #08090d);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 40px 90px -50px rgba(0, 0, 0, 0.9),
      0 0 0 1px rgba(255, 255, 255, 0.02) inset;
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0);
    white-space: nowrap; border: 0;
  }

  .strip-chrome {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.7rem 0.95rem;
    border-bottom: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.015);
  }
  .strip-dot { width: 11px; height: 11px; border-radius: 50%; background: var(--d); opacity: 0.9; }
  .strip-ws { display: flex; gap: 0.35rem; margin-left: 0.6rem; }
  .ws-name {
    font-family: var(--mono); font-size: 0.68rem; color: var(--faint);
    padding: 0.15rem 0.5rem; border-radius: 6px; border: 1px solid transparent;
    background: transparent; cursor: pointer;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .ws-name:hover { color: var(--muted); }
  .ws-name.is-active { color: var(--cyan); border-color: rgba(51,217,242,0.3); background: rgba(51,217,242,0.07); }
  .ws-name:focus-visible { outline: 2px solid var(--cyan); outline-offset: 2px; }
  .strip-hint { margin-left: auto; font-size: 0.68rem; color: var(--faint); }

  .strip-viewport {
    position: relative;
    isolation: isolate;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    scrollbar-width: none;
    padding: 1.1rem;
    scroll-padding-inline: 1.1rem;
  }
  .strip-viewport::-webkit-scrollbar { display: none; }
  .strip-viewport:focus-visible { outline: 2px solid var(--cyan); outline-offset: -2px; }

  .strip-track { display: flex; gap: 0.85rem; width: max-content; }
  .strip-track[hidden] { display: none; }

  .col {
    flex: none;
    display: flex;
    flex-direction: row;
    gap: 0.4rem;
    height: 340px;
    border-radius: 12px;
  }
  .col-narrow { width: 168px; }
  .col-normal { width: 236px; }
  .col-wide { width: 320px; }

  .col-windows {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .win {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 10px;
    overflow: hidden;
  }
  .win[hidden] { display: none; }
  .win-bar {
    display: flex; align-items: center;
    padding: 0.5rem 0.7rem;
    border-bottom: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.02);
    transition: background 0.2s, color 0.2s;
  }
  .win-app { font-family: var(--mono); font-size: 0.72rem; color: var(--muted); letter-spacing: 0.02em; }
  .win[aria-selected="true"] .win-bar { background: rgba(78, 134, 242, 0.1); }
  .win[aria-selected="true"] .win-app { color: var(--text); }
  .win-body { flex: 1; padding: 0.8rem 0.75rem; display: flex; flex-direction: column; gap: 0.5rem; overflow: hidden; }
  .ln { height: 7px; width: var(--lw); border-radius: 4px; background: rgba(255, 255, 255, 0.07); }

  /* app-flavored bodies */
  .body-term { background: #070a0d; }
  .body-term .ln { background: rgba(51, 217, 242, 0.16); }
  .body-term .ln:nth-child(3n) { background: rgba(51, 217, 242, 0.28); width: 30% !important; }
  .body-edit .ln:nth-child(4n+1) { background: rgba(155, 84, 240, 0.22); width: 22% !important; }
  .body-edit .ln:nth-child(3n) { background: rgba(78, 134, 242, 0.20); }
  .body-web .ln:first-child { height: 22px; background: var(--flow-soft); width: 100% !important; }
  .body-media { background: radial-gradient(circle at 30% 30%, rgba(155,84,240,0.18), transparent 70%), var(--surface); }
  .body-chat .ln:nth-child(even) { align-self: flex-end; background: rgba(78,134,242,0.18); }

  /* tabbed column — a vertical rail of peels along the left edge, no labels.
     Mirrors Nehir's TabbedColumnOverlay: the segments *share the column's
     height* (equal, height-distributing pills that scale with the column, not
     fixed chips), and the active tab is set apart by a wider, brighter pill —
     Nehir's overlay widens the active segment (8px vs 5px) and fills it with
     the accent color. Here the active pill is also a touch taller for extra
     emphasis. */
  .col-peels {
    flex: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    width: 16px;
    padding: 1px 0;
  }
  .peel {
    flex: 1 1 0;
    min-height: 10px;
    width: 6px;
    border-radius: 5px;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid var(--line);
    cursor: pointer;
    transition: width 0.22s cubic-bezier(0.22, 1, 0.36, 1),
      flex-grow 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.2s, border-color 0.2s, box-shadow 0.2s;
  }
  .peel:hover { width: 9px; background: rgba(255, 255, 255, 0.28); }
  .peel.is-active {
    flex-grow: 1.5;
    width: 12px;
    background: var(--flow);
    border-color: transparent;
    box-shadow: 0 0 12px -3px rgba(78, 134, 242, 0.75);
  }

  /* focus ring — slides to the focused *window* (not the whole column) */
  .focus-ring {
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    border: 2px solid transparent;
    border-radius: 12px;
    pointer-events: none;
    background: var(--flow) border-box;
    -webkit-mask: linear-gradient(#000 0 0) padding-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.4), 0 0 34px -6px rgba(78, 134, 242, 0.6);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      width 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      height 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform, width, height;
  }

  .strip-controls {
    display: flex; align-items: center; gap: 1rem;
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--line);
  }
  .strip-cap { flex: 1; text-align: center; font-size: 0.72rem; color: var(--faint); }
  .strip-arrow {
    width: 34px; height: 34px; flex: none;
    display: grid; place-items: center;
    font-size: 1rem; color: var(--muted);
    background: var(--surface-2); border: 1px solid var(--line-strong);
    border-radius: 9px; cursor: pointer;
    transition: color 0.15s, border-color 0.15s, transform 0.15s;
  }
  .strip-arrow:hover { color: var(--text); border-color: rgba(255,255,255,0.3); transform: translateY(-1px); }
  .strip-arrow:focus-visible { outline: 2px solid var(--cyan); outline-offset: 2px; }

  @media (max-width: 620px) {
    .col { height: 260px; }
    .strip-hint { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .strip-viewport { scroll-behavior: auto; }
    .focus-ring, .peel, .win-bar { transition: none; }
  }
</style>

<script>
  const viewport = document.getElementById("flow-viewport") as HTMLElement | null;
  const ring = document.getElementById("flow-ring") as HTMLElement | null;
  const live = document.getElementById("flow-live") as HTMLElement | null;
  const prev = document.getElementById("flow-prev");
  const next = document.getElementById("flow-next");
  const wsButtons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-ws-btn]"));

  if (viewport && ring) {
    const reduced = () => matchMedia("(prefers-reduced-motion: reduce)").matches;

    let track = viewport.querySelector<HTMLElement>(".strip-track:not([hidden])")!;
    let cols: HTMLElement[] = [];
    let focusedCol = 0;

    const winsOf = (col: HTMLElement) => Array.from(col.querySelectorAll<HTMLElement>(".win"));
    const activeIdx = (col: HTMLElement) => Number(col.dataset.active ?? "0");
    const activeWin = (col: HTMLElement) => winsOf(col)[activeIdx(col)];

    // The ring lives inside the scroll container and scrolls with the track, so
    // it must use content coordinates. Each .win's nearest positioned ancestor
    // is the viewport (nothing between is positioned), so offsetLeft/offsetTop
    // are already viewport-content coordinates — no drift once scrolled.
    const placeRing = () => {
      const col = cols[focusedCol];
      if (!col) return;
      const win = activeWin(col);
      if (!win) return;
      ring.style.width = `${win.offsetWidth}px`;
      ring.style.height = `${win.offsetHeight}px`;
      ring.style.transform = `translate(${win.offsetLeft}px, ${win.offsetTop}px)`;
    };

    const announce = (col: HTMLElement) => {
      if (!live) return;
      const win = activeWin(col);
      const app = win?.dataset.app ?? "Window";
      const wins = winsOf(col);
      const idx = activeIdx(col) + 1;
      const wsName = track.dataset.ws ?? "";
      let msg: string;
      if (col.dataset.mode === "tabs") {
        msg = `${app}, tab ${idx} of ${wins.length}, ${wsName} workspace`;
      } else if (wins.length > 1) {
        msg = `${app}, window ${idx} of ${wins.length}, column ${focusedCol + 1} of ${cols.length}`;
      } else {
        msg = `${app}, column ${focusedCol + 1} of ${cols.length}, ${wsName} workspace`;
      }
      live.textContent = msg;
    };

    // Reflect selection into ARIA: only the active window of the focused column
    // is the selected option.
    const syncSelection = () => {
      cols.forEach((col, ci) => {
        winsOf(col).forEach((win, wi) => {
          win.setAttribute("aria-selected", String(ci === focusedCol && wi === activeIdx(col)));
        });
      });
      const win = activeWin(cols[focusedCol]);
      if (win) viewport.setAttribute("aria-activedescendant", win.id);
    };

    const showTab = (col: HTMLElement, idx: number) => {
      const wins = winsOf(col);
      col.dataset.active = String(idx);
      wins.forEach((w, wi) => w.toggleAttribute("hidden", wi !== idx));
      col.querySelectorAll<HTMLElement>(".peel").forEach((p, pi) =>
        p.classList.toggle("is-active", pi === idx));
    };

    const scrollColIntoView = (col: HTMLElement) => {
      const target = col.offsetLeft - (viewport.clientWidth - col.offsetWidth) / 2;
      // Horizontal only — never scroll the page vertically to reveal the strip.
      viewport.scrollTo({ left: target, behavior: reduced() ? "auto" : "smooth" });
    };

    const focusColumn = (i: number, scroll = true) => {
      focusedCol = Math.max(0, Math.min(cols.length - 1, i));
      syncSelection();
      placeRing();
      announce(cols[focusedCol]);
      if (scroll) scrollColIntoView(cols[focusedCol]);
    };

    // Move within the focused column: cycle tabs (tabbed) or step between
    // stacked windows. No horizontal scroll — we stay in the same column.
    const moveWithinColumn = (delta: number) => {
      const col = cols[focusedCol];
      const wins = winsOf(col);
      if (wins.length < 2) return;
      const cur = activeIdx(col);
      if (col.dataset.mode === "tabs") {
        const nextIdx = (cur + delta + wins.length) % wins.length;
        showTab(col, nextIdx);
      } else {
        const nextIdx = Math.max(0, Math.min(wins.length - 1, cur + delta));
        if (nextIdx === cur) return;
        col.dataset.active = String(nextIdx);
      }
      syncSelection();
      placeRing();
      announce(col);
    };

    const bindColumn = (col: HTMLElement, ci: number) => {
      // Click a tab peel → switch the visible tab and focus that window.
      col.querySelectorAll<HTMLElement>(".peel").forEach((peel) => {
        peel.addEventListener("click", () => {
          showTab(col, Number(peel.dataset.peel));
          focusColumn(ci, false);
        });
      });
      // Click a stacked window → focus it.
      winsOf(col).forEach((win, wi) => {
        win.addEventListener("click", () => {
          if (col.dataset.mode !== "tabs") col.dataset.active = String(wi);
          focusColumn(ci, false);
        });
      });
    };

    const activateWorkspace = (wsKey: string, announceIt = true) => {
      const nextTrack = viewport.querySelector<HTMLElement>(`.strip-track[data-ws="${wsKey}"]`);
      if (!nextTrack || nextTrack === track) return;
      track.setAttribute("hidden", "");
      nextTrack.removeAttribute("hidden");
      track = nextTrack;
      cols = Array.from(track.querySelectorAll<HTMLElement>(".col"));
      cols.forEach(bindColumn);
      wsButtons.forEach((b) => {
        const on = b.dataset.wsBtn === wsKey;
        b.classList.toggle("is-active", on);
        b.setAttribute("aria-pressed", String(on));
      });
      viewport.scrollTo({ left: 0, behavior: "auto" });
      focusColumn(Number(track.dataset.focus ?? "0"), true);
      if (announceIt && live) {
        live.textContent = `${track.dataset.ws} workspace`;
        // Re-announce the focused window after the workspace name settles.
        requestAnimationFrame(() => announce(cols[focusedCol]));
      }
    };

    viewport.addEventListener("keydown", (e) => {
      switch (e.key) {
        case "ArrowRight": e.preventDefault(); focusColumn(focusedCol + 1); break;
        case "ArrowLeft": e.preventDefault(); focusColumn(focusedCol - 1); break;
        case "ArrowDown": e.preventDefault(); moveWithinColumn(1); break;
        case "ArrowUp": e.preventDefault(); moveWithinColumn(-1); break;
      }
    });
    prev?.addEventListener("click", () => focusColumn(focusedCol - 1));
    next?.addEventListener("click", () => focusColumn(focusedCol + 1));

    wsButtons.forEach((b) =>
      b.addEventListener("click", () => activateWorkspace(b.dataset.wsBtn!)));

    window.addEventListener("resize", placeRing);

    // Initial layout for the default workspace.
    cols = Array.from(track.querySelectorAll<HTMLElement>(".col"));
    cols.forEach(bindColumn);
    requestAnimationFrame(() => focusColumn(Number(track.dataset.focus ?? "0"), false));
  }
</script>
