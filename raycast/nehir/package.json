      "description": "Run nehirctl command consume-or-expel-window-left",
      "mode": "no-view"
    },
    {
      "name": "consume-window-right",
      "title": "Nehir: Consume or Expel Window Right",
      "description": "Run nehirctl command consume-or-expel-window-right",
      "mode": "no-view"
    },
