      "description": "Run nehirctl command rescue-offscreen-windows",
      "mode": "no-view"
    },
    {
      "name": "scratchpad-assign",
      "title": "Nehir: Assign Scratchpad",
      "description": "Run nehirctl command scratchpad assign",
      "mode": "no-view"
