      "description": "Run nehirctl command move-to-workspace down",
      "mode": "no-view"
    },
    {
      "name": "focus-monitor-prev",
      "title": "Nehir: Focus Previous Monitor",
      "description": "Run nehirctl command focus-monitor prev",
      "mode": "no-view"
    },
    {
      "name": "focus-monitor-next",
      "title": "Nehir: Focus Next Monitor",
      "description": "Run nehirctl command focus-monitor next",
      "mode": "no-view"
    },
    {
      "name": "focus-monitor-last",
      "title": "Nehir: Focus Last Monitor",
      "description": "Run nehirctl command focus-monitor last",
      "mode": "no-view"
    },
    {
      "name": "move-column-left",
      "title": "Nehir: Move Column Left",
      "description": "Run nehirctl command move-column left",
      "mode": "no-view"
    },
    {
      "name": "move-column-right",
      "title": "Nehir: Move Column Right",
      "description": "Run nehirctl command move-column right",
      "mode": "no-view"
    },
    {
      "name": "move-column-to-first",
      "title": "Nehir: Move Column to First",
      "description": "Run nehirctl command move-column-to-first",
      "mode": "no-view"
    },
    {
      "name": "move-column-to-last",
      "title": "Nehir: Move Column to Last",
      "description": "Run nehirctl command move-column-to-last",
      "mode": "no-view"
    },
    {
      "name": "toggle-column-tabbed",
