{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "nehir",
  "title": "Nehir",
  "description": "Control Nehir window manager through its nehirctl IPC CLI from Raycast.",
  "icon": "extension-icon.png",
  "author": "guria",
  "platforms": [
    "macOS"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "nehir",
      "title": "Control Nehir",
      "description": "Open searchable Nehir IPC commands and queries",
      "mode": "view"
    },
    {
      "name": "focus-left",
      "title": "Nehir: Focus Left",
      "description": "Focus the window to the left",
      "mode": "no-view"
    },
    {
      "name": "focus-right",
      "title": "Nehir: Focus Right",
      "description": "Focus the window to the right",
      "mode": "no-view"
    },
    {
      "name": "focus-up",
      "title": "Nehir: Focus Up",
      "description": "Focus the window above",
      "mode": "no-view"
    },
    {
      "name": "focus-down",
      "title": "Nehir: Focus Down",
      "description": "Focus the window below",
      "mode": "no-view"
    },
    {
      "name": "move-left",
      "title": "Nehir: Move Left",
      "description": "Move the focused window left",
      "mode": "no-view"
    },
    {
      "name": "move-right",
      "title": "Nehir: Move Right",
      "description": "Move the focused window right",
      "mode": "no-view"
    },
    {
      "name": "move-up",
      "title": "Nehir: Move Up",
      "description": "Move the focused window up",
      "mode": "no-view"
    },
    {
      "name": "move-down",
      "title": "Nehir: Move Down",
      "description": "Move the focused window down",
      "mode": "no-view"
    },
    {
      "name": "workspace-next",
      "title": "Nehir: Next Workspace",
      "description": "Switch to the next workspace",
      "mode": "no-view"
    },
    {
      "name": "workspace-prev",
      "title": "Nehir: Previous Workspace",
      "description": "Switch to the previous workspace",
      "mode": "no-view"
    },
    {
      "name": "toggle-fullscreen",
      "title": "Nehir: Toggle Fullscreen",
      "description": "Toggle Nehir-managed fullscreen",
      "mode": "no-view"
    },
    {
      "name": "toggle-floating",
      "title": "Nehir: Toggle Floating",
      "description": "Toggle focused window floating",
      "mode": "no-view"
    },
    {
      "name": "scratchpad-toggle",
      "title": "Nehir: Toggle Scratchpad",
      "description": "Show or hide the scratchpad window",
      "mode": "no-view"
    },
    {
      "name": "toggle-overview",
      "title": "Nehir: Toggle Overview",
      "description": "Open or close overview",
      "mode": "no-view"
    },
    {
      "name": "open-nehir-settings",
      "title": "Nehir: Open Settings",
      "description": "Open Nehir settings",
      "mode": "no-view"
    },
    {
      "name": "ping-ipc",
      "title": "Nehir: Ping IPC",
      "description": "Verify Nehir IPC reachability",
      "mode": "no-view"
    },
    {
      "name": "focus-previous",
      "title": "Nehir: Focus Previous",
      "description": "Run nehirctl command focus previous",
      "mode": "no-view"
    },
    {
      "name": "focus-down-or-left",
      "title": "Nehir: Focus Down or Left",
      "description": "Run nehirctl command focus down-or-left",
      "mode": "no-view"
    },
    {
      "name": "focus-up-or-right",
      "title": "Nehir: Focus Up or Right",
      "description": "Run nehirctl command focus up-or-right",
      "mode": "no-view"
    },
    {
      "name": "focus-window-top",
      "title": "Nehir: Focus Window Top",
      "description": "Run nehirctl command focus-window top",
      "mode": "no-view"
    },
    {
      "name": "focus-window-bottom",
      "title": "Nehir: Focus Window Bottom",
      "description": "Run nehirctl command focus-window bottom",
      "mode": "no-view"
    },
    {
      "name": "move-window-up",
      "title": "Nehir: Move Window Up",
      "description": "Run nehirctl command move-window-up",
      "mode": "no-view"
    },
    {
      "name": "move-window-down",
      "title": "Nehir: Move Window Down",
      "description": "Run nehirctl command move-window-down",
      "mode": "no-view"
    },
    {
      "name": "consume-window-left",
