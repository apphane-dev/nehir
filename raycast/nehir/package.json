      "description": "Run nehirctl command cycle-column-width forward",
      "mode": "no-view"
    },
    {
      "name": "cycle-column-width-backward",
      "title": "Nehir: Cycle Column Width Backward",
      "description": "Run nehirctl command cycle-column-width backward",
      "mode": "no-view"
    },
    {
      "name": "cycle-window-width-forward",
      "title": "Nehir: Cycle Window Width Forward",
      "description": "Run nehirctl command cycle-window-width forward",
      "mode": "no-view"
    },
    {
      "name": "cycle-window-width-backward",
      "title": "Nehir: Cycle Window Width Backward",
      "description": "Run nehirctl command cycle-window-width backward",
      "mode": "no-view"
    },
    {
      "name": "balance-sizes",
      "title": "Nehir: Balance Sizes",
      "description": "Run nehirctl command balance-sizes",
      "mode": "no-view"
    },
    {
