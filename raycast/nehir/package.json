    {
      "name": "toggle-workspace-bar",
      "title": "Nehir: Toggle Workspace Bar",
      "description": "Run nehirctl command toggle-workspace-bar",
      "mode": "no-view"
    },
    {
      "name": "toggle-native-fullscreen",
