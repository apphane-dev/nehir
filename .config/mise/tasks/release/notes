#!/usr/bin/env bash
#MISE description="Generate docs/releases/vX.Y.Z.md from pending changesets"
#USAGE arg "<version>" help="Release version, with or without leading v"
#USAGE flag "--since-tag <tag>" help="Only include changesets added since this tag (for prerelease diffs)"
set -euo pipefail

VERSION="${usage_version:-${1:-}}"
if [ -z "$VERSION" ]; then
  echo "Usage: mise run release:notes -- <version> [--since-tag <tag>]" >&2
  echo "Example: mise run release:notes -- 0.2.2" >&2
  echo "Example: mise run release:notes -- 0.3.0-rc.2 --since-tag v0.3.0-rc.1" >&2
  exit 1
fi
TAG="v${VERSION#v}"
ROOT_DIR="$(git rev-parse --show-toplevel)"
CHANGESET_DIR="$ROOT_DIR/.changeset"
RELEASE_DIR="$ROOT_DIR/docs/releases"
NOTES_FILE="$RELEASE_DIR/$TAG.md"

# Collect only changesets added since --since-tag (if provided)
SINCE_TAG="${usage_since_tag:-}"
if [ -n "$SINCE_TAG" ]; then
  if ! git rev-parse --verify --quiet "$SINCE_TAG" >/dev/null; then
    echo "Since tag does not exist: $SINCE_TAG" >&2
    exit 1
  fi
  CHANGESET_FILES=$(git diff --diff-filter=A --name-only "$SINCE_TAG"..HEAD -- .changeset/)
  # Filter to .md files excluding README, resolve to full paths
  INCLUDED_FILES=()
  for f in $CHANGESET_FILES; do
    base=$(basename "$f")
    if [ "$base" != "README.md" ] && [[ "$base" == *.md ]]; then
      INCLUDED_FILES+=("$ROOT_DIR/$f")
    fi
  done
  if [ ${#INCLUDED_FILES[@]} -eq 0 ]; then
    echo "No new changesets since $SINCE_TAG." >&2
    exit 1
  fi
else
  INCLUDED_FILES=()
  while IFS= read -r f; do
    INCLUDED_FILES+=("$f")
  done < <(find "$CHANGESET_DIR" -maxdepth 1 -type f -name '*.md' ! -iname 'README.md' | sort)
  if [ ${#INCLUDED_FILES[@]} -eq 0 ]; then
    echo "No pending changesets found in .changeset/*.md" >&2
    exit 1
  fi
fi

# Pass the list of files via a temp file so python doesn't choke on args
FILE_LIST=$(mktemp)
printf '%s\n' "${INCLUDED_FILES[@]}" > "$FILE_LIST"
trap 'rm -f "$FILE_LIST"' EXIT

python3 - "$CHANGESET_DIR" "$NOTES_FILE" "$TAG" "$FILE_LIST" <<'PY'
from pathlib import Path
import re
import sys

changeset_dir = Path(sys.argv[1])
notes_file = Path(sys.argv[2])
tag = sys.argv[3]
file_list = Path(sys.argv[4])

files = [Path(line.strip()) for line in file_list.read_text().splitlines() if line.strip()]
if not files:
    raise SystemExit("No pending changesets found")

pattern = re.compile(r"^---\s*\n(?P<frontmatter>.*?)\n---\s*\n(?P<body>.*)$", re.S)
release_line = re.compile(r'^\s*["\']?[^"\':]+["\']?\s*:\s*(major|minor|patch|none)\s*$', re.I)
contributors_line = re.compile(r'^\s*contributors\s*:\s*(?P<value>.+?)\s*$', re.I)
entries = []

def parse_contributors(value: str) -> list[str]:
    value = value.strip()
    if value.startswith("[") and value.endswith("]"):
        value = value[1:-1]
    contributors = []
    for item in value.split(","):
        handle = item.strip().strip('"\'').removeprefix("@")
        if not handle:
            continue
        if not re.fullmatch(r"[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?", handle):
            raise SystemExit(f"Invalid GitHub contributor handle: {handle}")
        contributors.append(handle)
    return contributors


def format_thanks(contributors: list[str]) -> str:
    links = [f"[@{handle}](https://github.com/{handle})" for handle in contributors]
    if not links:
        return ""
    if len(links) == 1:
        joined = links[0]
    elif len(links) == 2:
        joined = f"{links[0]} and {links[1]}"
    else:
        joined = f"{', '.join(links[:-1])}, and {links[-1]}"
    return f" Thanks {joined}."


for path in files:
    text = path.read_text().strip()
    match = pattern.match(text)
    if not match:
        raise SystemExit(f"Invalid changeset format: {path}")

    frontmatter = match.group("frontmatter").strip()
    body = match.group("body").strip()
    if not frontmatter:
        raise SystemExit(f"Empty changeset frontmatter: {path}")
    contributors = []
    for line in frontmatter.splitlines():
        if not line.strip():
            continue
        if release_line.match(line):
            continue
        contributor_match = contributors_line.match(line)
        if contributor_match:
            contributors.extend(parse_contributors(contributor_match.group("value")))
            continue
        raise SystemExit(f"Invalid Changesets frontmatter line in {path}: {line}")
    if not body:
        raise SystemExit(f"Empty changeset body: {path}")

    normalized = " ".join(line.strip() for line in body.splitlines() if line.strip())
    entries.append(normalized + format_thanks(contributors))

lines = ["## Changes", ""]
for item in entries:
    prefix = "- " if not item.startswith("- ") else ""
    lines.append(f"{prefix}{item}")

lines += [
    "",
    "## Notes",
    "",
    (
        "This is a prerelease build and is not signed or notarized. "
        "To open it, right-click the app and choose Open, then confirm in the dialog."
        if "-" in tag.lstrip("v")
        else "Nehir is distributed as a signed and notarized app. If macOS still shows a Gatekeeper warning, right-click the app and choose Open."
    ),
    "",
    "Nehir requires Accessibility permission to manage windows.",
    "",
]

notes_file.parent.mkdir(parents=True, exist_ok=True)
if notes_file.exists():
    raise SystemExit(f"Release notes already exist: {notes_file}")
notes_file.write_text("\n".join(lines))

print(f"Created {notes_file}")
print(f"Included {len(files)} pending changeset(s). Pending changesets stay in .changeset/ until the release workflow succeeds and clears them.")
PY
