#!/usr/bin/env bash
#MISE description="Render release notes from pending changesets to stdout"
#USAGE arg "<version>" help="Release version, with or without leading v"
#USAGE flag "--since-tag <tag>" help="Only include changesets added since this tag (for prerelease diffs)"
set -euo pipefail

VERSION="${usage_version:-${1:-}}"
if [ -z "$VERSION" ]; then
  echo "Usage: mise run release:notes -- <version> [--since-tag <tag>]" >&2
  echo "Example: mise run release:notes -- 0.2.2" >&2
  echo "Example: mise run release:notes -- 0.3.0-rc.2 --since-tag v0.3.0-rc.1" >&2
  exit 1
fi
TAG="v${VERSION#v}"
ROOT_DIR="$(git rev-parse --show-toplevel)"
CHANGESET_DIR="$ROOT_DIR/.changeset"

# Collect only changesets added since --since-tag (if provided)
SINCE_TAG="${usage_since_tag:-}"
if [ -n "$SINCE_TAG" ]; then
  if ! git rev-parse --verify --quiet "$SINCE_TAG" >/dev/null; then
    echo "Since tag does not exist: $SINCE_TAG" >&2
    exit 1
  fi
  CHANGESET_FILES=$(git diff --diff-filter=AM --name-only "$SINCE_TAG"..HEAD -- .changeset/)
  # Filter to .md files excluding README, resolve to full paths
  INCLUDED_FILES=()
  for f in $CHANGESET_FILES; do
    base=$(basename "$f")
    if [ "$base" != "README.md" ] && [[ "$base" == *.md ]]; then
      INCLUDED_FILES+=("$ROOT_DIR/$f")
    fi
  done
  if [ ${#INCLUDED_FILES[@]} -eq 0 ]; then
    echo "No new changesets since $SINCE_TAG." >&2
    exit 1
  fi
else
  INCLUDED_FILES=()
  while IFS= read -r f; do
    INCLUDED_FILES+=("$f")
  done < <(find "$CHANGESET_DIR" -maxdepth 1 -type f -name '*.md' ! -iname 'README.md' | sort)
  if [ ${#INCLUDED_FILES[@]} -eq 0 ]; then
    echo "No pending changesets found in .changeset/*.md" >&2
    exit 1
  fi
fi

# Pass the list of files via a temp file so python doesn't choke on args
FILE_LIST=$(mktemp)
printf '%s\n' "${INCLUDED_FILES[@]}" > "$FILE_LIST"
trap 'rm -f "$FILE_LIST"' EXIT

python3 - "$CHANGESET_DIR" "$TAG" "$FILE_LIST" <<'PY'
from pathlib import Path
import os
import re
import sys

changeset_dir = Path(sys.argv[1])
tag = sys.argv[2]
file_list = Path(sys.argv[3])
bypass_notarization = os.environ.get("RELEASE_BYPASS_NOTARIZATION", "false").lower() == "true"

files = [Path(line.strip()) for line in file_list.read_text().splitlines() if line.strip()]
if not files:
    raise SystemExit("No pending changesets found")

pattern = re.compile(r"^---\s*\n(?P<frontmatter>.*?)\n---\s*\n(?P<body>.*)$", re.S)
release_line = re.compile(r'^\s*["\']?[^"\':]+["\']?\s*:\s*(major|minor|patch|none)\s*$', re.I)
contributors_line = re.compile(r'^\s*contributors\s*:\s*(?P<value>.+?)\s*$', re.I)
breaking_prefix = re.compile(r"^(?:\*\*)?BREAKING(?: CHANGE)?(?::\*\*|\*\*:|:)\s*", re.I)
entries = []

def parse_contributors(value: str) -> list[str]:
    value = value.strip()
    if value.startswith("[") and value.endswith("]"):
        value = value[1:-1]
    contributors = []
    for item in value.split(","):
        handle = item.strip().strip('"\'').removeprefix("@")
        if not handle:
            continue
        if not re.fullmatch(r"[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?", handle):
            raise SystemExit(f"Invalid GitHub contributor handle: {handle}")
        contributors.append(handle)
    return contributors


def strip_breaking_prefix(body: str) -> tuple[str, bool]:
    stripped = body.lstrip()
    match = breaking_prefix.match(stripped)
    if not match:
        return body, False
    return stripped[match.end():].lstrip(), True


def format_thanks(contributors: list[str]) -> str:
    mentions = [f"@{handle}" for handle in contributors]
    if not mentions:
        return ""
    if len(mentions) == 1:
        joined = mentions[0]
    elif len(mentions) == 2:
        joined = f"{mentions[0]} and {mentions[1]}"
    else:
        joined = f"{', '.join(mentions[:-1])}, and {mentions[-1]}"
    return f"Thanks {joined}."


def append_sentence(line: str, sentence: str) -> str:
    if not sentence:
        return line
    separator = " " if line.rstrip().endswith((".", "!", "?")) else ". "
    return f"{line}{separator}{sentence}"


def append_thanks(rendered: list[str], contributors: list[str]) -> list[str]:
    thanks = format_thanks(contributors)
    if not thanks:
        return rendered
    for index in range(len(rendered) - 1, -1, -1):
        stripped = rendered[index].strip()
        if stripped and not is_list_item(stripped):
            rendered[index] = append_sentence(rendered[index], thanks)
            return rendered
    return rendered + ["", f"  {thanks}"]


def is_list_item(line: str) -> bool:
    return bool(re.match(r"^(?:[-*+] |\d+[.)] )", line))


def trim_blank_edges(lines: list[str]) -> list[str]:
    while lines and not lines[0].strip():
        lines.pop(0)
    while lines and not lines[-1].strip():
        lines.pop()
    return lines


def render_entry(body: str, contributors: list[str]) -> list[str]:
    body_lines = trim_blank_edges([line.rstrip() for line in body.splitlines()])
    if not body_lines:
        return []

    # Preserve intentionally structured Markdown. In particular, a summary
    # followed by bullets should render as one top-level change with nested
    # detail bullets, not as a single flattened sentence containing "-" text.
    if len(body_lines) == 1:
        line = body_lines[0].strip()
        if is_list_item(line):
            return append_thanks([line], contributors)
        return [append_sentence(f"- {line}", format_thanks(contributors))]

    first = body_lines[0].strip()
    if is_list_item(first):
        return append_thanks([line.strip() if line.strip() else "" for line in body_lines], contributors)

    rendered = [f"- {first}"]
    for line in body_lines[1:]:
        stripped = line.strip()
        rendered.append(f"  {stripped}" if stripped else "")
    return append_thanks(rendered, contributors)


for path in files:
    text = path.read_text().strip()
    match = pattern.match(text)
    if not match:
        raise SystemExit(f"Invalid changeset format: {path}")

    frontmatter = match.group("frontmatter").strip()
    body = match.group("body").strip()
    if not frontmatter:
        raise SystemExit(f"Empty changeset frontmatter: {path}")
    contributors = []
    is_breaking = False
    for line in frontmatter.splitlines():
        if not line.strip():
            continue
        release_match = release_line.match(line)
        if release_match:
            is_breaking = is_breaking or release_match.group(1).lower() == "major"
            continue
        contributor_match = contributors_line.match(line)
        if contributor_match:
            contributors.extend(parse_contributors(contributor_match.group("value")))
            continue
        raise SystemExit(f"Invalid Changesets frontmatter line in {path}: {line}")
    if not body:
        raise SystemExit(f"Empty changeset body: {path}")

    body, body_marks_breaking = strip_breaking_prefix(body)
    is_breaking = is_breaking or body_marks_breaking
    if not body:
        raise SystemExit(f"Empty changeset body after BREAKING marker: {path}")

    rendered = render_entry(body, contributors)
    if not rendered:
        raise SystemExit(f"Empty changeset body: {path}")
    entries.append({"breaking": is_breaking, "rendered": rendered})

def append_section(lines: list[str], title: str, section_entries: list[list[str]]) -> None:
    if not section_entries:
        return
    if lines:
        lines.append("")
    lines.extend([f"## {title}", ""])
    for entry in section_entries:
        lines.extend(entry)
        lines.append("")
    while lines and lines[-1] == "":
        lines.pop()

breaking_entries = [entry["rendered"] for entry in entries if entry["breaking"]]
change_entries = [entry["rendered"] for entry in entries if not entry["breaking"]]

lines = []
append_section(lines, "Breaking changes", breaking_entries)
append_section(lines, "Changes", change_entries)

if bypass_notarization:
    distribution_note = (
        "Nehir is signed but not notarized in this release while Apple notarization processing is delayed. "
        "If macOS shows a Gatekeeper warning, right-click the app and choose Open."
    )
else:
    distribution_note = "Nehir is distributed as a signed and notarized app. If macOS still shows a Gatekeeper warning, right-click the app and choose Open."

lines += [
    "",
    "## Notes",
    "",
    distribution_note,
    "",
    "Nehir requires Accessibility permission to manage windows.",
    "",
]

# Pure markdown to stdout so the caller can pipe it straight into the GitHub
# release description. Status goes to stderr to keep stdout clean.
print(f"Rendered release notes for {tag} from {len(files)} changeset(s).", file=sys.stderr)
print("\n".join(lines))
PY
