#!/usr/bin/env bash
#MISE description="Apply release plan by updating Info.plist and release notes"
#USAGE arg "<version>" help="Release version, with or without leading v"
set -euo pipefail

VERSION="${usage_version:-${1:-}}"
if [ -z "$VERSION" ]; then
  echo "Usage: mise run release:apply -- <version>" >&2
  exit 1
fi
VERSION="${VERSION#v}"
ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

/usr/libexec/PlistBuddy -c "Set :CFBundleShortVersionString $VERSION" Info.plist

NOTES_FILE="docs/releases/v$VERSION.md"
if [ ! -f "$NOTES_FILE" ]; then
  mise run release:notes -- "$VERSION"
else
  echo "Release notes already exist: $NOTES_FILE"
fi
