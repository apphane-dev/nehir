#!/usr/bin/env bash
#MISE description="Stamp Info.plist with the release version"
#USAGE arg "<version>" help="Release version, with or without leading v"
set -euo pipefail

VERSION="${usage_version:-${1:-}}"
if [ -z "$VERSION" ]; then
  echo "Usage: mise run release:apply -- <version>" >&2
  exit 1
fi
VERSION="${VERSION#v}"
BASE_VERSION="${VERSION%%-*}"
ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

/usr/libexec/PlistBuddy -c "Set :CFBundleShortVersionString $BASE_VERSION" Info.plist
